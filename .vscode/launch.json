{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Linux Project",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/linux/RaylibTest",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build linux Project",
            "miDebuggerPath": "/usr/bin/gdb",
            "logging": {
                "moduleLoad": false,
                "trace": false,
                "engineLogging": false,
                "programOutput": true,
                "exceptions": false
            },
            "linux": {
                "MIMode": "gdb",
                "miDebuggerPath": "/usr/bin/gdb"
            }
        },
        {
            "name": "Launch Web Project",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8000/RaylibTest.html",
            "webRoot": "${workspaceFolder}/build/web",
            "preLaunchTask": "Start Python HTTP Server"
        }
    ]
}