        {
            "label": "Build Web Projects",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build-wasm"
            ],
            "group": "build",
            "problemMatcher": [],
            "dependsOn": "Configure Web Project"
        },
        {
